# ─────────────────────────────────────────────────────────────────────────────
# FaceU — Configuration
# Committed to git intentionally (no secrets here).
# Last updated: switched to EdgeFace-S based on benchmark results.
#
# Benchmark summary (Raspberry Pi 5):
#   w600k_r50   → 3 FPS  | TAR 100% | ID%(log)  9.4% | median_sim 0.3111  ← LOW (Unknown bug)
#   EdgeFace-S  → 61 FPS | TAR 100% | ID%(log) 84.4% | median_sim 0.6038  ← WINNER
#   EdgeFace-XS → 95 FPS | TAR 100% | ID%(log) 73.4% | median_sim 0.5303
# ─────────────────────────────────────────────────────────────────────────────

# ── Paths ─────────────────────────────────────────────────────────────────────
MODELS_DIR=models
DATASET_DIR=dataset
LOG_DIR=log

# ── Production recognition model (used by webserver / camera pipeline) ────────
# Switched from w600k_r50.onnx → EdgeFace-S based on benchmark results.
# w600k_r50 produced median_sim=0.31 on real captures (below the 0.40 threshold
# → everything labelled "Unknown"). EdgeFace-S produces 0.60 median_sim.
RECOGNITION_MODEL=edgeface_s_gamma_05.onnx

# ── Recognition hyperparams ───────────────────────────────────────────────────
# Raised from 0.40 → 0.50 because EdgeFace-S scores are higher (median 0.60).
# 0.50 gives a comfortable safety margin and reduces false positives.
# If you still see too many Unknowns, lower to 0.45.
RECOGNITION_THRESHOLD=0.50

# ── Camera / pipeline ─────────────────────────────────────────────────────────
# Raised TARGET_FPS 5 → 15. EdgeFace-S recognition takes 16ms (was 287ms),
# so workers are no longer the bottleneck. MediaPipe face detection is now
# the limit — 10 FPS is safe on Pi 5 without thermal throttling.
TARGET_FPS=15
MOTION_FPS=2                     # FPS during motion-detection phase (keep low — saves CPU)
NO_FACE_TIMEOUT=10.0             # seconds without a face before reverting to motion mode

# Raised 3 → 5. With 61 FPS recognition and 10 FPS camera, we collect 5 crops
# easily within 0.5s. More votes = more robust majority decision.
CONSECUTIVE_FRAMES=5

FIAQ_THRESHOLD=0.40              # minimum face quality score to accept a crop
MIN_FACE_SIZE=50                 # minimum bounding box dimension (px)
MOVEMENT_THRESHOLD=1500          # pixel-change count to trigger face-detection phase

# ── Benchmark settings ────────────────────────────────────────────────────────
BENCH_LATENCY_RUNS=100           # inference repetitions for latency measurement
BENCH_WINDOW_SECONDS=10.0        # no_face_timeout window used in FPS-gain calculation
BENCH_THRESHOLD=0.50             # keep in sync with RECOGNITION_THRESHOLD

# ── Models to benchmark ───────────────────────────────────────────────────────
BENCH_MODELS=w600k_r50.onnx,edgeface_s_gamma_05.onnx,edgeface_xs_gamma_06.onnx

# ── Webhook & API ─────────────────────────────────────────────────────────────
API_KEY=your_secret_api_key_here
WEBHOOK_URL=
WEBHOOK_API_KEY=

