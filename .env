# ─────────────────────────────────────────────────────────────────────────────
# FaceU — Configuration
# Committed to git intentionally (no secrets here).
# ─────────────────────────────────────────────────────────────────────────────

# ── Paths ─────────────────────────────────────────────────────────────────────
MODELS_DIR=models
DATASET_DIR=dataset
LOG_DIR=log

# ── Production recognition model (used by webserver / camera pipeline) ────────
# Change this to switch the active model for the live system.
# Must match a filename in MODELS_DIR after download.
RECOGNITION_MODEL=w600k_r50.onnx

# ── Recognition hyperparams ───────────────────────────────────────────────────
RECOGNITION_THRESHOLD=0.40       # cosine similarity threshold; raise to reduce unknowns

# ── Camera / pipeline ─────────────────────────────────────────────────────────
TARGET_FPS=5                     # FPS during face-detection phase
MOTION_FPS=2                     # FPS during motion-detection phase
NO_FACE_TIMEOUT=10.0             # seconds without a face before reverting to motion mode
CONSECUTIVE_FRAMES=3             # face crops collected before a majority-vote decision
FIAQ_THRESHOLD=0.40              # minimum face quality score to accept a crop
MIN_FACE_SIZE=50                 # minimum bounding box dimension (px)
MOVEMENT_THRESHOLD=1500          # pixel-change count to trigger face-detection phase

# ── Benchmark settings ────────────────────────────────────────────────────────
BENCH_LATENCY_RUNS=100           # inference repetitions for latency measurement
BENCH_WINDOW_SECONDS=10.0        # no_face_timeout window used in FPS-gain calculation
BENCH_THRESHOLD=0.40             # similarity threshold to use during benchmark eval

# ── Models to benchmark (comma-separated, must match filenames in MODELS_DIR) ─
# Remove any model you have not downloaded to skip it automatically.
BENCH_MODELS=w600k_r50.onnx,edgeface_s_gamma_05.onnx,edgeface_xs_gamma_06.onnx,mobilefacenet_int8.onnx
